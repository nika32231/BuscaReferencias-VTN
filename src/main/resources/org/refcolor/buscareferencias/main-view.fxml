<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/fxml"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.refcolor.buscareferencias.controller.DrawingController"
            prefHeight="700.0" prefWidth="1000.0"
            stylesheets="@style.css">

    <top>
        <ToolBar>
            <Button text="🗑 Limpiar" onAction="#handleClear">
                <tooltip><Tooltip text="Borrar todo el lienzo"/></tooltip>
            </Button>
            <Button text="↩ Deshacer" onAction="#handleUndo"/>
            <Button text="↪ Rehacer" onAction="#handleRedo"/>
            <Separator orientation="VERTICAL"/>
            <ToggleButton fx:id="btnDraw" text="✎ Dibujar" selected="true" styleClass="tool-button"/>
            <ToggleButton fx:id="btnErase" text="🧽 Borrar" styleClass="tool-button"/>
            <Separator orientation="VERTICAL"/>
            <Button text="🔍 Analizar (Consola)" onAction="#handleSearch" styleClass="analyze-button"/>
        </ToolBar>
    </top>

    <left>
        <VBox spacing="10" prefWidth="160">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="Partes del Cuerpo" style="-fx-font-weight: bold"/>
            <VBox fx:id="paletteContainer" spacing="5">
                <!-- Los botones de la paleta se generarán dinámicamente -->
            </VBox>
        </VBox>
    </left>

    <center>
        <SplitPane orientation="VERTICAL" dividerPositions="0.6">
            <StackPane style="-fx-background-color: #e8e8e8; -fx-padding: 10;">
                <VBox alignment="CENTER" styleClass="canvas-container" fillWidth="false">
                    <Canvas fx:id="canvas" width="600" height="400"
                            onMousePressed="#handleMousePressed"
                            onMouseDragged="#handleMouseDragged"
                            onMouseReleased="#handleMouseReleased"/>
                </VBox>
            </StackPane>
            <VBox spacing="5" style="-fx-padding: 10; -fx-background-color: white;">
                <Label text="Galería de Referencias (Simulada)" style="-fx-font-weight: bold"/>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: white;">
                    <FlowPane fx:id="galleryPane" hgap="10" vgap="10" style="-fx-padding: 10;">
                        <!-- Las imágenes aparecerán aquí -->
                    </FlowPane>
                </ScrollPane>
            </VBox>
        </SplitPane>
    </center>

    <right>
        <VBox spacing="10" prefWidth="250" style="-fx-background-color: #f9f9f9; -fx-border-color: #cccccc; -fx-border-width: 0 0 0 1;">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="Términos de Búsqueda" style="-fx-font-weight: bold"/>
            <ListView fx:id="termsListView" VBox.vgrow="ALWAYS" />
            <HBox spacing="5">
                <TextField fx:id="newTermField" promptText="Nuevo término..." HBox.hgrow="ALWAYS"/>
                <Button text="+" onAction="#handleAddTerm"/>
            </HBox>
            <Button text="🚀 Lanzar Búsqueda Web" onAction="#handleWebSearch" maxWidth="Infinity" styleClass="analyze-button"/>
        </VBox>
    </right>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <Label text="Estado:"/>
            <Label fx:id="statusLabel" text="Listo para dibujar"/>
            <Pane HBox.hgrow="ALWAYS" />
            <ProgressBar fx:id="progressBar" visible="false" prefWidth="150" />
        </HBox>
    </bottom>

</BorderPane>
