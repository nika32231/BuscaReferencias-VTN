<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/fxml"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.refcolor.buscareferencias.controller.DrawingController"
            prefHeight="600.0" prefWidth="800.0">

    <top>
        <ToolBar style="-fx-spacing: 10; -fx-padding: 5 10 5 10;">
            <Button text="🗑 Limpiar" onAction="#handleClear" tooltip="$clearTooltip"/>
            <Button text="↩ Deshacer" onAction="#handleUndo"/>
            <Button text="↪ Rehacer" onAction="#handleRedo"/>
            <Separator orientation="VERTICAL"/>
            <ToggleButton fx:id="btnDraw" text="✎ Dibujar" selected="true" style="-fx-font-weight: bold;"/>
            <ToggleButton fx:id="btnErase" text="🧽 Borrar" style="-fx-font-weight: bold;"/>
            <Separator orientation="VERTICAL"/>
            <Button text="🔍 Analizar (Consola)" onAction="#handleSearch" style="-fx-base: #e1f5fe;"/>
            <fx:define>
                <Tooltip fx:id="clearTooltip" text="Borrar todo el lienzo"/>
            </fx:define>
        </ToolBar>
    </top>

    <left>
        <VBox spacing="10" prefWidth="150">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="Partes del Cuerpo" style="-fx-font-weight: bold"/>
            <VBox fx:id="paletteContainer" spacing="5">
                <!-- Los botones de la paleta se generarán dinámicamente -->
            </VBox>
        </VBox>
    </left>

    <center>
        <StackPane style="-fx-background-color: #e8e8e8; -fx-padding: 20;">
            <VBox alignment="CENTER" style="-fx-background-color: white; -fx-border-color: #666666; -fx-border-width: 2px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5); -fx-max-width: 604px; -fx-max-height: 504px;">
                <Canvas fx:id="canvas" width="600" height="500"
                        onMousePressed="#handleMousePressed"
                        onMouseDragged="#handleMouseDragged"
                        onMouseReleased="#handleMouseReleased"/>
            </VBox>
        </StackPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <padding>
                <Insets top="5" right="5" bottom="5" left="5"/>
            </padding>
            <Label text="Estado:"/>
            <Label fx:id="statusLabel" text="Listo para dibujar"/>
        </HBox>
    </bottom>

</BorderPane>
